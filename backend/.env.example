# Database Configuration
DB_TYPE=sqlite
DATABASE_URL=./database.sqlite

# PostgreSQL (optional, for future use)
NUXT_POSTGRES_URL=postgresql://username:password@host:port/database_name

# Session Configuration
NUXT_SESSION_NAME=nuxt-session
NODE_ENV=development

# JWT Configuration (change this to a long random string in production)
NUXT_JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
